APP_NAME=Study Platform API
APP_VERSION=1.0.0

POSTGRES_USER=study_user
POSTGRES_PASSWORD=study_pass
POSTGRES_DB=study_platform
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

SECRET_KEY=super-secret-key
